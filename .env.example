# Browser-safe Stytch Consumer project token
NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN=
# Standalone KeyWay API. Omit only when running the legacy same-origin routes locally.
NEXT_PUBLIC_KEYWAY_API_URL=http://localhost:3001

# Server-only Stytch Consumer project credentials
STYTCH_PROJECT_ID=
STYTCH_SECRET=
STYTCH_ENVIRONMENT=test

# Standalone API deployment. Existing Stytch wallet metadata is imported on first login.
DATABASE_URL=
KEYWAY_ALLOWED_ORIGINS=http://localhost:3000

# Server-only Lit Chipotle runtime credentials
LIT_USAGE_API_KEY=
