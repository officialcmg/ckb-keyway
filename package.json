{
  "name": "@ckb-keyway/react",
  "version": "0.0.1",
  "description": "Email-authenticated CKB wallet and Fiber payment infrastructure",
  "private": true,
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/react",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:sdk": "tsup src/sdk/react/index.ts --tsconfig tsconfig.sdk.json --format esm --dts --platform browser --out-dir dist/react --clean",
    "build:api": "tsup server/index.ts --tsconfig tsconfig.sdk.json --format esm --platform node --out-dir dist/api --clean",
    "api": "node dist/api/index.js",
    "dev:api": "node --import tsx server/index.ts",
    "start": "next start",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify:lit": "node --experimental-strip-types --env-file=.env.local scripts/verify-lit.ts",
    "build:package": "npm run build:sdk && node scripts/prepare-package.mjs",
    "pack:sdk": "npm run build:package && npm pack ./dist/package",
    "publish:sdk": "npm run build:package && npm publish ./dist/package"
  },
  "dependencies": {
    "@ckb-ccc/core": "^1.16.1",
    "@fiber-pay/sdk": "^0.2.7",
    "@nervosnetwork/fiber-js": "^0.9.0-rc7",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "postgres": "^3.4.9",
    "stytch": "^14.2.0"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
