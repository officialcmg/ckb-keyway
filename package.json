{
  "name": "ckb-keyway",
  "version": "0.1.0",
  "description": "Email-authenticated CKB wallet and Fiber payment infrastructure",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/browser",
    "dist/server",
    "lit-actions",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:sdk": "tsup src/sdk/browser/index.ts --tsconfig tsconfig.sdk.json --format esm --dts --platform browser --out-dir dist/browser --clean && tsup src/sdk/server/index.ts --tsconfig tsconfig.sdk.json --format esm --dts --platform node --out-dir dist/server --clean",
    "build:api": "tsup server/index.ts --tsconfig tsconfig.sdk.json --format esm --platform node --out-dir dist/api --clean",
    "api": "node dist/api/index.js",
    "dev:api": "node --import tsx server/index.ts",
    "start": "next start",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "verify:lit": "node --experimental-strip-types --env-file=.env.local scripts/verify-lit.ts",
    "prepack": "npm run build:sdk"
  },
  "dependencies": {
    "@ckb-ccc/core": "^1.16.1",
    "@fiber-pay/sdk": "^0.2.7",
    "@nervosnetwork/fiber-js": "^0.9.0-rc7",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "postgres": "^3.4.9",
    "stytch": "^14.2.0"
  },
  "devDependencies": {
    "@stytch/nextjs": "^22.0.11",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
